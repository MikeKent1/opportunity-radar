PRODUCT_HUNT_API_SECRET=YOUR_PRODUCT_HUNT_API_SECRET
PRODUCT_HUNT_ACCESS_TOKEN=YOUR_PRODUCT_HUNT_ACCESS_TOKEN
KAGGLE_API_TOKEN=YOUR_KAGGLE_API_TOKEN
RSS_FEED_URLS=https://example.com/feed.xml,https://example.org/rss
RSS_KEYWORDS=
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET
