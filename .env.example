# Apify Instagram social monitoring
APIFY_TOKEN=YOUR_APIFY_TOKEN
INSTAGRAM_ACTOR_ID=sones/instagram-posts-scraper-lowcost
INSTAGRAM_ACTOR_MODE=lowcost
INSTAGRAM_POSTS_LIMIT=2
INSTAGRAM_ROTATION_BUCKETS=4
INSTAGRAM_SOURCE_USERNAMES=
INSTAGRAM_NEWER_THAN_DAYS=5
INSTAGRAM_NEWER_THAN_LOOKBACK_MINUTES=30
APIFY_TIMEOUT_MS=180000

# Optional AI-assisted reward classification for ambiguous web/social giveaways.
# Server-side only. Use as a GitHub Secret or local maintenance secret.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_CLASSIFIER_MODEL=gpt-5.4-mini
AI_REWARD_CLASSIFIER_ENABLED=true
AI_REWARD_CLASSIFIER_MODE=uncertain
OPENAI_ENRICHMENT_MODEL=gpt-5.4-mini
AI_GIVEAWAY_ENRICHMENT_ENABLED=true
AI_ENRICHMENT_BACKFILL_LIMIT=80
AI_ENRICHMENT_REPROCESS=false
